// ─────────────────────────────────────────────
//  AIRpipe — Authentication & Core API
// ─────────────────────────────────────────────

const API_BASE = ""; // URL base (relativa funciona con ngrok si se sirve desde el mismo host)

function getAuthHeaders() {
    const token = localStorage.getItem('draw_token');
    return {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`,
        'ngrok-skip-browser-warning': 'true'
    };
}

function updateAuthUI() {
    const token = localStorage.getItem('draw_token');
    const authModal = document.getElementById('auth-modal');
    if (token) {
        authModal.classList.add('hidden');
    } else {
        authModal.classList.remove('hidden');
    }
}

// Auth Event Listeners
document.getElementById('switch-to-register').onclick = () => {
    document.getElementById('login-view').style.display = 'none';
    document.getElementById('register-view').style.display = 'block';
};

document.getElementById('switch-to-login').onclick = () => {
    document.getElementById('register-view').style.display = 'none';
    document.getElementById('login-view').style.display = 'block';
};

document.getElementById('login-form').onsubmit = async (e) => {
    e.preventDefault();
    const email = document.getElementById('login-email').value;
    const password = document.getElementById('login-password').value;

    try {
        const resp = await fetch(`${API_BASE}/auth/login`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password })
        });
        const data = await resp.json();
        if (resp.ok) {
            localStorage.setItem('draw_token', data.access_token);
            updateAuthUI();
            location.reload(); // Recargar para cargar proyectos del usuario
        } else {
            alert(data.error || "Error al iniciar sesión");
        }
    } catch (err) {
        alert("Error de conexión con el servidor");
    }
};

document.getElementById('register-form').onsubmit = async (e) => {
    e.preventDefault();
    const email = document.getElementById('register-email').value;
    const password = document.getElementById('register-password').value;

    try {
        const resp = await fetch(`${API_BASE}/auth/register`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password })
        });
        const data = await resp.json();
        if (resp.ok) {
            alert("Registro exitoso. Ahora puedes iniciar sesión.");
            document.getElementById('switch-to-login').click();
        } else {
            alert(data.error || "Error al registrarse");
        }
    } catch (err) {
        alert("Error de conexión con el servidor");
    }
};

// Initial state check
updateAuthUI();

// ─────────────────────────────────────────────
//  AIRpipe — canvas.js
//  Fase 1: dibujo de tuberías y nodos
// ─────────────────────────────────────────────

// ── Constantes de color y estilo ──────────────
const COLOR_GRID = '#E0E0E0';
const COLOR_GRID_SUB = '#F5F5F5';
const COLOR_LINEA = '#005EAA';
const COLOR_LINEA_PREV = 'rgba(0, 94, 170, 0.45)';
const COLOR_COMPRESOR = '#424242';
const COLOR_CONSUMO = '#D32F2F';
const COLOR_COMPRESOR_BORDER = '#757575';
const COLOR_CONSUMO_BORDER = '#EF5350';

const GROSOR_LINEA = 2;
const RADIO_NODO = 10;
const PIXELS_POR_METRO = 50; // 1 metro = 50px
const PASO_GRID = PIXELS_POR_METRO; // Grid de 1 metro

// OPT-10: Constante única para el límite de cámara (antes duplicada en wheel y mousemove)
const MAX_CAMERA_OFFSET = 50; // px — límite para no salir del primer cuadrante

// ── Modos de herramienta ──────────────────────
const MODO = {
    NINGUNO: 'ninguno',
    LINEA: 'linea',
    COMPRESOR: 'compresor',
    CONSUMO: 'consumo',
    VALVULA: 'valvula',
    ACOTAR: 'acotar',
};

// ── Estado global ─────────────────────────────
let modoActual = MODO.NINGUNO;
let lineaIniciada = false;
let puntoInicio = null;   // {x, y} (World Coords)
let puntoMouse = null;   // {x, y} (World Coords)
let cotaInicio = null;    // {x, y} primer punto de la cota
let cotaSiendoEditada = null; // Cota que se está editando actualmente

// Viewport (Cámara)
let viewState = {
    scale: 1.0,
    offsetX: 0,
    offsetY: 0
};

// Mouse Pan State
let isPanning = false;
let lastPanX = 0;
let lastPanY = 0;

/** @type {Array<{tipo: 'linea'|'nodo', datos: object}>} */
let historial = [];

// Resultados de cálculo (Dimensionamiento, Piezas, Válvulas)
let resultadosCalculo = null; // Líneas procesadas con diámetros
let piezasCalculo = null;     // Piezas detectadas (Codos, Tes, Cruces)
let valvulasCalculo = null;   // Válvulas automáticas
let bomCalculo = null;        // Resumen de materiales

// ── Variables de Plano de Fondo (Blueprint) ──
let bgImageObj = null;        // Objeto Image() para renderizar
let bgBase64 = null;          // String Base64 para guardarlo en DB
let bgUrl = null;             // URL de la imagen si ya se subió al servidor
let bgScale = 1.0;
let bgOpacity = 0.5;

// ── Referencias DOM ───────────────────────────
const canvas = document.getElementById('mainCanvas');
const ctx = canvas.getContext('2d');
const wrapper = document.getElementById('canvas-wrapper');
const modeIndicator = document.getElementById('mode-indicator');
const statusText = document.getElementById('status-text');
const lengthInput = document.getElementById('lengthInput');

const btnLine = document.getElementById('btn-line');
const btnCompresor = document.getElementById('btn-compresor');
const btnConsumo = document.getElementById('btn-consumo');
const btnValvula = document.getElementById('btn-valvula');
const btnAcotar = document.getElementById('btn-acotar');
const btnUndo = document.getElementById('btn-undo');
const btnClear = document.getElementById('btn-clear');
const btnGenerar = document.getElementById('btn-generar');
const floatingDimInput = document.getElementById('floating-dim-input');

// Elementos del Plano de Fondo
const btnLoadBg = document.getElementById('btn-load-bg');
const bgInput = document.getElementById('bg-input');
const bgControls = document.getElementById('bg-controls');
const inputBgOpacity = document.getElementById('bg-opacity');
const inputBgScale = document.getElementById('bg-scale');
const valBgOpacity = document.getElementById('bg-opacity-val');
const valBgScale = document.getElementById('bg-scale-val');
const btnRemoveBg = document.getElementById('btn-remove-bg');

// OPT-4: Cache del bounding rect del canvas — se actualiza solo en resize
let canvasRect = null;
function updateCanvasRect() {
    canvasRect = canvas.getBoundingClientRect();
}

// ─────────────────────────────────────────────
//  OPT-1: Throttling de redraw con requestAnimationFrame
// ─────────────────────────────────────────────

let _rafPending = false;

/** Programa un redraw en el próximo frame de animación (evita redraws duplicados) */
function scheduleRedraw() {
    if (!_rafPending) {
        _rafPending = true;
        requestAnimationFrame(() => {
            _rafPending = false;
            redraw();
        });
    }
}

// ─────────────────────────────────────────────
//  OPT-3: Cache de puntos de snap
// ─────────────────────────────────────────────

let _snapPointsCache = null;

/** Invalida el cache de puntos de snap. Llamar siempre que cambie historial. */
function invalidateSnapCache() {
    _snapPointsCache = null;
    resultadosCalculo = null; // Para guardar resultados del dimensionamiento
    piezasCalculo = null;     // Para guardar piezas detectadas (Codos, Tes)
    valvulasCalculo = null;   // Para guardar válvulas automáticas
}

/** Devuelve la lista de puntos de interés para snap (cacheada). */
function getSnapPoints() {
    if (_snapPointsCache !== null) return _snapPointsCache;
    const puntos = [];
    for (const accion of historial) {
        if (accion.tipo === 'linea') {
            const { x1, y1, x2, y2 } = accion.datos;
            // Extremos
            puntos.push({ x: x1, y: y1, tipo: 'extremo' });
            puntos.push({ x: x2, y: y2, tipo: 'extremo' });
            // Punto medio
            puntos.push({ x: (x1 + x2) / 2, y: (y1 + y2) / 2, tipo: 'medio' });
        } else if (accion.tipo === 'nodo') {
            puntos.push({ x: accion.datos.x, y: accion.datos.y, tipo: 'extremo' });
        }
    }
    _snapPointsCache = puntos;
    return puntos;
}

// ─────────────────────────────────────────────
//  Utilidades
// ─────────────────────────────────────────────

/** Ajusta el canvas al tamaño del wrapper */
function resizeCanvas() {
    canvas.width = wrapper.clientWidth;
    canvas.height = wrapper.clientHeight;
    updateCanvasRect(); // OPT-4: actualizar rect en resize
    redraw();
}

/** Helper para dibujar el símbolo de válvula */
function renderValvula(x, y, anguloGrados, color) {
    ctx.save();
    ctx.translate(x, y);
    ctx.rotate(anguloGrados * Math.PI / 180);

    // Símbolo Bowtie
    const S = 6 / viewState.scale;
    ctx.beginPath();
    ctx.moveTo(-S, -S / 1.5); ctx.lineTo(0, 0); ctx.lineTo(-S, S / 1.5); ctx.closePath();
    ctx.moveTo(S, -S / 1.5); ctx.lineTo(0, 0); ctx.lineTo(S, S / 1.5); ctx.closePath();

    ctx.fillStyle = color;
    ctx.fill();
    ctx.lineWidth = 1 / viewState.scale;
    ctx.strokeStyle = '#FFFFFF';
    ctx.stroke();

    ctx.restore();
}


/** Convierte coordenadas de pantalla a mundo */
function toWorld(screenX, screenY) {
    return {
        x: (screenX - viewState.offsetX) / viewState.scale,
        y: (screenY - viewState.offsetY) / viewState.scale
    };
}

/** Convierte coordenadas de mundo a pantalla */
function toScreen(worldX, worldY) {
    return {
        x: worldX * viewState.scale + viewState.offsetX,
        y: worldY * viewState.scale + viewState.offsetY
    };
}

/** Actualiza el texto de estado en el panel */
function setStatus(msg) {
    statusText.textContent = msg;
}

/** Muestra / oculta el indicador de modo flotante */
function updateModeIndicator() {
    const labels = {
        [MODO.NINGUNO]: null,
        [MODO.LINEA]: '✏️  Modo: Tubería',
        [MODO.COMPRESOR]: '⚙️  Modo: Compresor',
        [MODO.CONSUMO]: '🔴  Modo: Punto de Consumo',
        [MODO.ACOTAR]: '📏  Modo: Acotar',
    };
    const label = labels[modoActual];
    if (label) {
        modeIndicator.textContent = label;
        modeIndicator.classList.remove('hidden');
    } else {
        modeIndicator.classList.add('hidden');
    }
}

/** Marca el botón activo en el panel */
function setActiveButton(btn) {
    [btnLine, btnCompresor, btnConsumo, btnAcotar].forEach(b => b.classList.remove('active'));
    if (btn) btn.classList.add('active');
}

// ─────────────────────────────────────────────
//  Dibujo
// ─────────────────────────────────────────────

/**
 * OPT-2: Dibuja la cuadrícula de fondo con paths agrupados.
 * Antes: 1 stroke() por línea → hasta 600 llamadas GPU por frame.
 * Ahora: 1 stroke() por estilo → 2-4 llamadas GPU por frame.
 */
function drawGrid() {
    const s = viewState.scale;

    // Límites visibles en coordenadas de mundo
    const left = -viewState.offsetX / s;
    const top = -viewState.offsetY / s;
    const right = (canvas.width - viewState.offsetX) / s;
    const bottom = (canvas.height - viewState.offsetY) / s;

    // Paso adaptativo: duplicar hasta que cada celda mida al menos 20px en pantalla
    let gridStep = PASO_GRID;
    while (gridStep * s < 20) gridStep *= 2;

    // Alinear al grid adaptativo (nunca menos de 0)
    const startX = Math.max(0, Math.floor(left / gridStep) * gridStep);
    const startY = Math.max(0, Math.floor(top / gridStep) * gridStep);

    const thinLine = 0.5 / s; // grosor constante en pantalla

    ctx.save();

    // ── Líneas principales del grid (un solo path) ──
    ctx.strokeStyle = COLOR_GRID;
    ctx.lineWidth = thinLine;
    ctx.beginPath();
    for (let x = startX; x <= right; x += gridStep) {
        ctx.moveTo(x, top);
        ctx.lineTo(x, bottom);
    }
    for (let y = startY; y <= bottom; y += gridStep) {
        ctx.moveTo(left, y);
        ctx.lineTo(right, y);
    }
    ctx.stroke();

    // ── Sub-líneas a la mitad (solo si hay espacio suficiente) ──
    if (gridStep * s > 50) {
        ctx.strokeStyle = COLOR_GRID_SUB;
        ctx.beginPath();
        for (let x = startX; x <= right; x += gridStep) {
            ctx.moveTo(x + gridStep / 2, top);
            ctx.lineTo(x + gridStep / 2, bottom);
        }
        for (let y = startY; y <= bottom; y += gridStep) {
            ctx.moveTo(left, y + gridStep / 2);
            ctx.lineTo(right, y + gridStep / 2);
        }
        ctx.stroke();
    }

    // ── Etiquetas de coordenadas ──
    ctx.fillStyle = '#9E9E9E';
    ctx.font = `${10 / s}px Consolas, monospace`;
    for (let x = startX; x <= right; x += gridStep) {
        ctx.fillText(`${Math.round(x / PIXELS_POR_METRO)}m`, x + 2 / s, top + 12 / s);
    }
    for (let y = startY; y <= bottom; y += gridStep) {
        ctx.fillText(`${Math.round(y / PIXELS_POR_METRO)}m`, left + 2 / s, y - 2 / s);
    }

    // ── Ejes Principales (0,0) — un solo path ──
    ctx.strokeStyle = '#666';
    ctx.lineWidth = 2 / s;
    ctx.beginPath();
    if (left <= 0 && right >= 0) {
        ctx.moveTo(0, Math.max(0, top));
        ctx.lineTo(0, bottom);
    }
    if (top <= 0 && bottom >= 0) {
        ctx.moveTo(Math.max(0, left), 0);
        ctx.lineTo(right, 0);
    }
    ctx.stroke();

    ctx.restore();
}

/** Dibuja una línea de tubería */
function drawLinea(x1, y1, x2, y2, preview = false) {
    ctx.save();
    ctx.strokeStyle = preview ? COLOR_LINEA_PREV : COLOR_LINEA;
    ctx.lineWidth = GROSOR_LINEA / viewState.scale;
    ctx.lineCap = 'round';
    if (preview) {
        const d = 6 / viewState.scale;
        const g = 4 / viewState.scale;
        ctx.setLineDash([d, g]);
    }
    ctx.beginPath();
    ctx.moveTo(x1, y1);
    ctx.lineTo(x2, y2);
    ctx.stroke();
    ctx.restore();
}

/** Dibuja un nodo (compresor o consumo) */
function drawNodo(tipo, x, y) {
    const isCompresor = tipo === 'compresor';
    const fillColor = isCompresor ? COLOR_COMPRESOR : COLOR_CONSUMO;
    const borderColor = isCompresor ? COLOR_COMPRESOR_BORDER : COLOR_CONSUMO_BORDER;
    const r = RADIO_NODO / viewState.scale;

    ctx.save();
    ctx.beginPath();
    ctx.arc(x, y, r, 0, Math.PI * 2);
    ctx.fillStyle = fillColor;
    ctx.fill();
    ctx.strokeStyle = borderColor;
    ctx.lineWidth = 2 / viewState.scale;
    ctx.stroke();

    ctx.fillStyle = isCompresor ? '#BDBDBD' : '#EF9A9A';
    ctx.font = `${9 / viewState.scale}px Segoe UI, sans-serif`;
    ctx.textAlign = 'center';
    ctx.fillText(isCompresor ? 'C' : 'P', x, y + r + 11 / viewState.scale);
    ctx.restore();
}

/**
 * OPT-5: Redibuja todo el canvas desde el historial.
 * Las líneas se dibujan en un solo path batch; los nodos por tipo.
 */
/**
 * OPT-5: Redibuja todo el canvas desde el historial.
 * Las líneas se dibujan en un solo path batch; los nodos por tipo.
 */
function redraw() {
    if (!ctx) return;
    try {
        ctx.clearRect(0, 0, canvas.width, canvas.height);

        ctx.save();
        ctx.translate(viewState.offsetX, viewState.offsetY);
        ctx.scale(viewState.scale, viewState.scale);

        // ── Renderizar Plano de Fondo (Blueprint) ──
        if (bgImageObj) {
            ctx.save();
            ctx.globalAlpha = bgOpacity;
            // Dibujar la imagen escalada por bgScale empezando en (0,0) del mundo iterativo
            ctx.drawImage(bgImageObj, 0, 0, bgImageObj.width * bgScale, bgImageObj.height * bgScale);
            ctx.restore();
        }

        drawGrid();

        // ── Batch: todas las líneas del historial en un solo path ──
        const lineasHistorial = historial.filter(a => a.tipo === 'linea');
        if (lineasHistorial.length > 0) {
            ctx.save();
            ctx.strokeStyle = COLOR_LINEA;
            ctx.lineWidth = GROSOR_LINEA / viewState.scale;
            ctx.lineCap = 'round';
            ctx.beginPath();
            for (const accion of lineasHistorial) {
                const { x1, y1, x2, y2 } = accion.datos;
                ctx.moveTo(x1, y1);
                ctx.lineTo(x2, y2);
            }
            ctx.stroke();
            ctx.restore();
        }

        // ── Nodos (cada uno necesita arc individual, pero agrupamos fill/stroke por tipo) ──
        const compresores = historial.filter(a => a.tipo === 'nodo' && a.datos.tipo === 'compresor');
        const consumos = historial.filter(a => a.tipo === 'nodo' && a.datos.tipo === 'consumo');
        const r = RADIO_NODO / viewState.scale;

        // Fill compresores
        if (compresores.length > 0) {
            ctx.save();
            ctx.fillStyle = COLOR_COMPRESOR;
            ctx.strokeStyle = COLOR_COMPRESOR_BORDER;
            ctx.lineWidth = 2 / viewState.scale;
            for (const accion of compresores) {
                const { x, y } = accion.datos;
                ctx.beginPath();
                ctx.arc(x, y, r, 0, Math.PI * 2);
                ctx.fill();
                ctx.stroke();
            }
            // Etiquetas compresores
            ctx.fillStyle = '#BDBDBD';
            ctx.font = `${9 / viewState.scale}px Segoe UI, sans-serif`;
            ctx.textAlign = 'center';
            for (const accion of compresores) {
                const { x, y } = accion.datos;
                ctx.fillText('C', x, y + r + 11 / viewState.scale);
            }
            ctx.restore();
        }

        // Fill consumos
        if (consumos.length > 0) {
            ctx.save();
            ctx.fillStyle = COLOR_CONSUMO;
            ctx.strokeStyle = COLOR_CONSUMO_BORDER;
            ctx.lineWidth = 2 / viewState.scale;
            for (const accion of consumos) {
                const { x, y } = accion.datos;
                ctx.beginPath();
                ctx.arc(x, y, r, 0, Math.PI * 2);
                ctx.fill();
                ctx.stroke();
            }
            // Etiquetas consumos
            ctx.fillStyle = '#EF9A9A';
            ctx.font = `${9 / viewState.scale}px Segoe UI, sans-serif`;
            ctx.textAlign = 'center';
            for (const accion of consumos) {
                const { x, y } = accion.datos;
                ctx.fillText('P', x, y + r + 11 / viewState.scale);
            }
            ctx.restore();
        }

        // ── Preview de línea en progreso ──
        if (modoActual === MODO.LINEA && lineaIniciada && puntoInicio && puntoMouse) {
            drawLinea(puntoInicio.x, puntoInicio.y, puntoMouse.x, puntoMouse.y, true);
            ctx.save();
            ctx.beginPath();
            ctx.arc(puntoInicio.x, puntoInicio.y, 4, 0, Math.PI * 2);
            ctx.fillStyle = COLOR_LINEA;
            ctx.fill();
            ctx.restore();
        }

        // ── Marcadores de Punto Medio (diamantes permanentes) ──
        ctx.save();
        ctx.strokeStyle = '#9C27B0'; // Violeta
        ctx.lineWidth = 1.5 / viewState.scale;
        const dm = 4 / viewState.scale; // Half-size del diamante
        for (const accion of historial) {
            if (accion.tipo !== 'linea') continue;
            const { x1, y1, x2, y2 } = accion.datos;
            const mx = (x1 + x2) / 2;
            const my = (y1 + y2) / 2;
            ctx.beginPath();
            ctx.moveTo(mx, my - dm);
            ctx.lineTo(mx + dm, my);
            ctx.lineTo(mx, my + dm);
            ctx.lineTo(mx - dm, my);
            ctx.closePath();
            ctx.stroke();
        }
        ctx.restore();

        // ── Indicador de Snap a Punto ──
        if (snapPoint) {
            ctx.save();
            const isMidpoint = snapPoint.tipo === 'medio';
            const r_snap = 6 / viewState.scale;
            ctx.lineWidth = 2 / viewState.scale;
            ctx.strokeStyle = isMidpoint ? '#9C27B0' : '#FF9800';

            if (isMidpoint) {
                // Diamante resaltado para punto medio
                ctx.beginPath();
                ctx.moveTo(snapPoint.x, snapPoint.y - r_snap * 1.4);
                ctx.lineTo(snapPoint.x + r_snap * 1.4, snapPoint.y);
                ctx.lineTo(snapPoint.x, snapPoint.y + r_snap * 1.4);
                ctx.lineTo(snapPoint.x - r_snap * 1.4, snapPoint.y);
                ctx.closePath();
                ctx.stroke();
            } else {
                // Círculo para extremo
                ctx.beginPath();
                ctx.arc(snapPoint.x, snapPoint.y, r_snap, 0, Math.PI * 2);
                ctx.stroke();
            }
            ctx.restore();
        }

        // ── Indicador de Snap Angular ──
        if (angleSnapPoint) {
            ctx.save();
            ctx.fillStyle = COLOR_LINEA;
            ctx.font = `${12 / viewState.scale}px Consolas, monospace`;
            ctx.fillText(`${angleSnapPoint.angle}°`,
                angleSnapPoint.x + 10 / viewState.scale,
                angleSnapPoint.y - 10 / viewState.scale);
            ctx.restore();
        }

        // ── Guías Inteligentes ──
        if (activeGuides.length > 0) {
            ctx.save();
            ctx.strokeStyle = '#00BCD4';
            ctx.lineWidth = 1 / viewState.scale;
            const dashLen = 5 / viewState.scale;
            ctx.setLineDash([dashLen, dashLen]);
            ctx.beginPath();
            for (const guia of activeGuides) {
                ctx.moveTo(guia.x1, guia.y1);
                ctx.lineTo(guia.x2, guia.y2);
            }
            ctx.stroke();

            // Cruces en los orígenes de las guías
            const cr = 3 / viewState.scale;
            ctx.setLineDash([]);
            ctx.beginPath();
            for (const guia of activeGuides) {
                ctx.moveTo(guia.x1 - cr, guia.y1 - cr);
                ctx.lineTo(guia.x1 + cr, guia.y1 + cr);
                ctx.moveTo(guia.x1 - cr, guia.y1 + cr);
                ctx.lineTo(guia.x1 + cr, guia.y1 - cr);
            }
            ctx.stroke();
            ctx.restore();
        }

        // ── Resultados de Cálculo (Diámetros) ──
        if (resultadosCalculo) {
            ctx.save();
            ctx.font = `bold ${12 / viewState.scale}px Arial, sans-serif`;
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';
            ctx.fillStyle = '#00BCD4'; // Cyan para resaltar

            for (const linea of resultadosCalculo) {
                if (linea.diametro) {
                    const mx = (linea.x1 + linea.x2) / 2;
                    const my = (linea.y1 + linea.y2) / 2;

                    // Calcular ángulo para rotar texto
                    const dx = linea.x2 - linea.x1;
                    const dy = linea.y2 - linea.y1;
                    let angle = Math.atan2(dy, dx);

                    // Mantener texto legible (no boca abajo)
                    if (angle > Math.PI / 2 || angle < -Math.PI / 2) {
                        angle += Math.PI;
                    }

                    ctx.save();
                    ctx.translate(mx, my);
                    ctx.rotate(angle);
                    // Offset vertical pequeño para no tapar la línea
                    const offset = -8 / viewState.scale;
                    ctx.fillText(`Ø${linea.diametro}`, 0, offset);
                    ctx.restore();
                }
            }
            ctx.restore();
        }

        // ── Piezas Detectadas (Codos, Tes, Cruces) ──
        if (piezasCalculo) {
            ctx.save();
            const rp = 6 / viewState.scale; // Radio del marcador
            ctx.font = `bold ${10 / viewState.scale}px Arial, sans-serif`;
            ctx.textAlign = 'center';
            ctx.textBaseline = 'middle';

            for (const pieza of piezasCalculo) {
                if (pieza.tipo === 'Union') {
                    // Dibujar cuadrado azul para Union
                    const sz = rp * 1.8;
                    ctx.fillStyle = '#2196F3'; // Azul
                    ctx.fillRect(pieza.x - sz / 2, pieza.y - sz / 2, sz, sz);
                    ctx.lineWidth = 1 / viewState.scale;
                    ctx.strokeStyle = '#FFFFFF';
                    ctx.strokeRect(pieza.x - sz / 2, pieza.y - sz / 2, sz, sz);
                } else if (pieza.tipo === 'Te Igual') {
                    // Dibujar cuadrado naranja para Te Igual (Acorde a la leyenda)
                    const sz = rp * 1.8;
                    ctx.fillStyle = '#FF9800'; // Naranja
                    ctx.fillRect(pieza.x - sz / 2, pieza.y - sz / 2, sz, sz);
                    ctx.lineWidth = 1 / viewState.scale;
                    ctx.strokeStyle = '#FFFFFF';
                    ctx.strokeRect(pieza.x - sz / 2, pieza.y - sz / 2, sz, sz);
                } else if (pieza.tipo === 'Tapon') {
                    // Dibujar círculo rojo para Tapon
                    ctx.beginPath();
                    ctx.arc(pieza.x, pieza.y, rp, 0, 2 * Math.PI);
                    ctx.fillStyle = '#F44336'; // Rojo
                    ctx.fill();
                    ctx.lineWidth = 1 / viewState.scale;
                    ctx.strokeStyle = '#FFFFFF';
                    ctx.stroke();
                } else if (pieza.tipo === 'Codo 45' || pieza.tipo === 'Te Lateral 45') {
                    // Dibujar diamante naranja para piezas de 45 grados
                    ctx.fillStyle = '#FF9800'; // Naranja
                    ctx.beginPath();
                    ctx.moveTo(pieza.x, pieza.y - rp * 1.2);
                    ctx.lineTo(pieza.x + rp * 1.2, pieza.y);
                    ctx.lineTo(pieza.x, pieza.y + rp * 1.2);
                    ctx.lineTo(pieza.x - rp * 1.2, pieza.y);
                    ctx.closePath();
                    ctx.fill();
                    ctx.lineWidth = 1 / viewState.scale;
                    ctx.strokeStyle = '#FFFFFF';
                    ctx.stroke();
                } else {
                    // Dibujar círculo coloreado según tipo (Te genérica, etc)
                    ctx.beginPath();
                    ctx.arc(pieza.x, pieza.y, rp, 0, 2 * Math.PI);

                    if (pieza.tipo === 'Codo') ctx.fillStyle = '#4CAF50'; // Verde
                    else if (pieza.tipo === 'Te') ctx.fillStyle = '#FF9800'; // Naranja
                    else if (pieza.tipo === 'Cruz') ctx.fillStyle = '#9C27B0'; // Morado
                    else ctx.fillStyle = '#FF9800'; // Fallback

                    ctx.fill();
                    ctx.lineWidth = 1 / viewState.scale;
                    ctx.strokeStyle = '#FFFFFF';
                    ctx.stroke();
                }

                ctx.fillStyle = '#FFFFFF';
                let label = '';
                if (pieza.tipo === 'Codo') label = 'C';
                else if (pieza.tipo === 'Codo 45') label = '45';
                else if (pieza.tipo === 'Te' || pieza.tipo === 'Te Igual') label = 'T';
                else if (pieza.tipo === 'Te Lateral 45') label = 'L';
                else if (pieza.tipo === 'Cruz') label = '+';
                else if (pieza.tipo === 'Union') label = 'U';
                else if (pieza.tipo === 'Tapon') label = 'X';
                ctx.fillText(label, pieza.x, pieza.y);
            }
            ctx.restore();
        }

        // ── Válvulas Automáticas (Cálculo) ──
        if (valvulasCalculo) {
            ctx.save();
            for (const v of valvulasCalculo) {
                renderValvula(v.x, v.y, v.angulo, '#00BCD4');
            }
            ctx.restore();
        }

        // ── Válvulas Manuales (Historial) ──
        const manualValves = historial.filter(a => a.tipo === 'valvula_manual');
        for (const mv of manualValves) {
            renderValvula(mv.datos.x, mv.datos.y, mv.datos.angulo, '#FFC107'); // Color ámbar para manuales
        }

        // ── Preview de Válvula (Cursor) ──
        if (modoActual === MODO.VALVULA && puntoMouse && !isPanning) {
            const snap = getLineSnap(puntoMouse.x, puntoMouse.y);
            if (snap) {
                renderValvula(snap.x, snap.y, snap.angulo, 'rgba(0, 188, 212, 0.6)');
            }
        }

        // ── Cotas (Historial) ──
        const cotas = historial.filter(a => a.tipo === 'cota');
        for (const c of cotas) {
            renderCota(c.datos);
        }

        // ── Preview de Cota (Cursor) ──
        if (modoActual === MODO.ACOTAR && cotaInicio && puntoMouse && !isPanning) {
            renderCota({
                x1: cotaInicio.x, y1: cotaInicio.y,
                x2: puntoMouse.x, y2: puntoMouse.y,
                offset: 30 / viewState.scale
            }, true);
        }

        ctx.restore(); // Restaurar cámara
    } catch (e) {
        console.error("Error en redraw:", e);
        setStatus("Error visual: " + e.message);
    }
}

// ─────────────────────────────────────────────
//  Renderizado de Cotas
// ─────────────────────────────────────────────

/** Renderiza una cota (acotación) estilo AutoCAD */
function renderCota(datos, isPreview = false) {
    const { x1, y1, x2, y2, offset } = datos;

    const dx = x2 - x1;
    const dy = y2 - y1;
    const length = Math.hypot(dx, dy);
    if (length < 1) return;

    const ux = dx / length;
    const uy = dy / length;
    const px = -uy;
    const py = ux;

    const off = offset || 30 / viewState.scale;

    const cx1 = x1 + px * off;
    const cy1 = y1 + py * off;
    const cx2 = x2 + px * off;
    const cy2 = y2 + py * off;

    const ext = 5 / viewState.scale;
    const alpha = isPreview ? 0.5 : 1.0;
    const color = isPreview ? `rgba(255, 215, 0, ${alpha})` : '#FFD700';
    const lineWidth = 1 / viewState.scale;

    ctx.save();
    ctx.strokeStyle = color;
    ctx.fillStyle = color;
    ctx.lineWidth = lineWidth;
    ctx.setLineDash(isPreview ? [4 / viewState.scale, 4 / viewState.scale] : []);

    // Líneas de extensión
    ctx.beginPath();
    ctx.moveTo(x1, y1);
    ctx.lineTo(cx1 + px * ext, cy1 + py * ext);
    ctx.moveTo(x2, y2);
    ctx.lineTo(cx2 + px * ext, cy2 + py * ext);
    ctx.stroke();

    // Línea de cota
    ctx.setLineDash([]);
    ctx.beginPath();
    ctx.moveTo(cx1, cy1);
    ctx.lineTo(cx2, cy2);
    ctx.stroke();

    // Flechas
    const arrowSize = 8 / viewState.scale;

    ctx.beginPath();
    ctx.moveTo(cx1, cy1);
    ctx.lineTo(cx1 + ux * arrowSize + px * arrowSize * 0.3, cy1 + uy * arrowSize + py * arrowSize * 0.3);
    ctx.lineTo(cx1 + ux * arrowSize - px * arrowSize * 0.3, cy1 + uy * arrowSize - py * arrowSize * 0.3);
    ctx.closePath();
    ctx.fill();

    ctx.beginPath();
    ctx.moveTo(cx2, cy2);
    ctx.lineTo(cx2 - ux * arrowSize + px * arrowSize * 0.3, cy2 - uy * arrowSize + py * arrowSize * 0.3);
    ctx.lineTo(cx2 - ux * arrowSize - px * arrowSize * 0.3, cy2 - uy * arrowSize - py * arrowSize * 0.3);
    ctx.closePath();
    ctx.fill();

    // Texto de medida
    const metros = (length / PIXELS_POR_METRO).toFixed(2);
    const midX = (cx1 + cx2) / 2;
    const midY = (cy1 + cy2) / 2;
    const fontSize = Math.max(10, 12 / viewState.scale);

    ctx.font = `bold ${fontSize}px 'Inter', sans-serif`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'bottom';

    let angle = Math.atan2(dy, dx);
    if (angle > Math.PI / 2) angle -= Math.PI;
    if (angle < -Math.PI / 2) angle += Math.PI;

    ctx.save();
    ctx.translate(midX, midY);
    ctx.rotate(angle);

    const textWidth = ctx.measureText(`${metros} m`).width;
    ctx.fillStyle = 'rgba(10, 25, 47, 0.85)';
    ctx.fillRect(-textWidth / 2 - 3, -fontSize - 2, textWidth + 6, fontSize + 2);

    ctx.fillStyle = color;
    ctx.fillText(`${metros} m`, 0, -3 / viewState.scale);
    ctx.restore();

    ctx.restore();
}

/** 
 * Detecta si el mouse está sobre el texto de una cota.
 * Retorna la cota y su área de detección si hay hit.
 */
function getCotaAt(wx, wy) {
    const cotas = historial.filter(a => a.tipo === 'cota');
    for (const c of cotas) {
        const { x1, y1, x2, y2, offset } = c.datos;
        const dx = x2 - x1;
        const dy = y2 - y1;
        const length = Math.hypot(dx, dy);
        if (length < 1) continue;

        const ux = dx / length;
        const uy = dy / length;
        const px = -uy;
        const py = ux;
        const off = offset || 30 / viewState.scale;

        const midX = (x1 + x2) / 2 + px * off;
        const midY = (y1 + y2) / 2 + py * off;

        // Área de detección (aprox 40x20 world units, depende del zoom)
        const hitW = 60 / viewState.scale;
        const hitH = 30 / viewState.scale;

        // Comprobar si wx, wy está cerca del centro
        const dMouse = Math.hypot(wx - midX, wy - midY);
        if (dMouse < hitH) { // Simplificado: círculo de detección
            return { cota: c, midX, midY };
        }
    }
    return null;
}

// ─────────────────────────────────────────────
//  Lógica de herramientas
// ─────────────────────────────────────────────

/** Cambia el modo activo */
function setModo(modo) {
    if (modoActual === modo) {
        modoActual = MODO.NINGUNO;
        lineaIniciada = false;
        puntoInicio = null;
        setActiveButton(null);
        setStatus('Selecciona una herramienta para comenzar.');
    } else {
        modoActual = modo;
        lineaIniciada = false;
        puntoInicio = null;

        const btnMap = {
            [MODO.LINEA]: btnLine,
            [MODO.COMPRESOR]: btnCompresor,
            [MODO.CONSUMO]: btnConsumo,
            [MODO.VALVULA]: btnValvula,
            [MODO.ACOTAR]: btnAcotar,
        };
        setActiveButton(btnMap[modo] || null);

        const statusMap = {
            [MODO.LINEA]: 'Clic para iniciar tubería. Segundo clic para terminarla.',
            [MODO.COMPRESOR]: 'Clic en el canvas para colocar un Compresor.',
            [MODO.CONSUMO]: 'Clic en el canvas para colocar un Punto de Consumo.',
            [MODO.VALVULA]: 'Clic sobre una tubería para colocar una Válvula de aislamiento.',
            [MODO.ACOTAR]: 'Clic en el primer punto a acotar. Segundo clic para terminar.',
        };
        setStatus(statusMap[modo] || '');
    }
    updateModeIndicator();
    redraw();
}

/** Deshace la última acción */
function undo() {
    if (historial.length === 0) {
        setStatus('No hay acciones para deshacer.');
        return;
    }
    historial.pop();
    invalidateSnapCache(); // OPT-3
    lineaIniciada = false;
    puntoInicio = null;
    redraw();
    setStatus(`Acción deshecha. (${historial.length} elemento${historial.length !== 1 ? 's' : ''} en historial)`);
}

/** Limpia todo el canvas */
function clearAll() {
    historial = [];
    invalidateSnapCache(); // OPT-3
    lineaIniciada = false;
    puntoInicio = null;
    redraw();
    setStatus('Canvas limpiado.');
}

const svgModal = document.getElementById('svg-modal');
const svgContainer = document.getElementById('svg-container');
const btnDownload = document.getElementById('btn-download');
const btnClose = document.getElementById('btn-close');

// BOM References
const bomModal = document.getElementById('bom-modal');
const bomBody = document.getElementById('bom-body');
const btnShowBom = document.getElementById('btn-show-bom');
const btnCloseBom = document.getElementById('btn-close-bom');
const btnCopyBom = document.getElementById('btn-copy-bom');

/** Exporta el JSON del plano, lo envía al backend y muestra el SVG */
async function generarPlano() {
    const lineas = historial
        .filter(a => a.tipo === 'linea')
        .map(a => a.datos);

    const nodos = historial
        .filter(a => a.tipo === 'nodo')
        .map(a => a.datos);

    const valvulas_manuales = historial
        .filter(a => a.tipo === 'valvula_manual')
        .map(a => a.datos);

    const plano = {
        lineas,
        nodos,
        valvulas_manuales,
        tipo_red: document.getElementById('select-tipo-red').value || 'lineal',
        caudal_scfm: parseFloat(document.getElementById('input-caudal').value) || 0,
    };

    setStatus('Generando plano, por favor espera...');

    try {
        const response = await fetch('/procesar', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(plano)
        });

        if (!response.ok) {
            throw new Error(`Error del servidor: ${response.status}`);
        }

        const data = await response.json();

        if (data.svg) {
            svgContainer.innerHTML = data.svg;
            svgModal.classList.remove('hidden');
            setStatus('Plano generado exitosamente.');

            // Guardar resultados para mostrar en canvas
            if (data.lineas) {
                resultadosCalculo = data.lineas;
                piezasCalculo = data.piezas;
                valvulasCalculo = data.valvulas;
                bomCalculo = data.bom; // Guardar BOM
                actualizarTablaBOM(data.bom);
                alert(`Plano generado exitosamente.\n\nCaudal: ${data.caudal_scfm} SCFM\nTipo Red: ${data.tipo_red}`);
            }
            redraw();

            btnDownload.onclick = () => {
                const blob = new Blob([data.svg], { type: 'image/svg+xml' });
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = 'plano_airpipe.svg';
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
            };

            const btnDownloadDxf = document.getElementById('btn-download-dxf');
            if (data.dxf) {
                btnDownloadDxf.style.display = 'inline-block';
                btnDownloadDxf.onclick = () => {
                    // Convertir base64 a blob
                    const byteCharacters = atob(data.dxf);
                    const byteNumbers = new Array(byteCharacters.length);
                    for (let i = 0; i < byteCharacters.length; i++) {
                        byteNumbers[i] = byteCharacters.charCodeAt(i);
                    }
                    const byteArray = new Uint8Array(byteNumbers);
                    const blob = new Blob([byteArray], { type: 'application/dxf' });

                    const url = URL.createObjectURL(blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = 'plano_airpipe.dxf';
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                };
            } else {
                btnDownloadDxf.style.display = 'none';
            }

            // Limpiar contenedor SVG al cerrar el modal (ahorro memoria)
            btnClose.onclick = () => {
                svgModal.classList.add('hidden');
                svgContainer.innerHTML = '';
            };
        } else {
            console.error('Respuesta sin SVG:', data);
            setStatus('Error: El servidor no devolvió un SVG.');
        }

    } catch (err) {
        console.error('Error al generar plano:', err);
        setStatus('Error al generar plano: ' + err.message);
    }
}

/** Renderiza los datos del BOM en la tabla del modal */
function actualizarTablaBOM(bom, infoStock = null) {
    if (!bom) return;
    let html = '';

    const categories = [
        { key: 'tuberias', title: 'Tuberías (Metros Lineales)' },
        { key: 'accesorios', title: 'Accesorios (Fittings)' },
        { key: 'valvulas', title: 'Válvulas y Equipos' }
    ];

    categories.forEach(cat => {
        const items = bom[cat.key];
        if (items && items.length > 0) {
            html += `<tr><td colspan="4" class="bom-cat-header">${cat.title}</td></tr>`;
            items.forEach(item => {
                let stockStatus = '';
                let bgColor = '';

                if (infoStock) {
                    const match = infoStock.find(s => s.original_description === item.descripcion);
                    if (match) {
                        const codeLabel = match.matched_code !== 'N/A' ? `[${match.matched_code}] ` : '';
                        stockStatus = `<td style="font-size: 11px; color: ${getStatusColor(match.status)};">${codeLabel}${match.status} (${match.current_stock})</td>`;
                    }
                }

                html += `
                    <tr>
                        <td>${item.descripcion}</td>
                        <td style="text-align: right; padding-right: 20px; font-weight: bold; color: #FFF;">${item.cantidad}</td>
                        <td style="color: #8B9FD3;">${item.unidad}</td>
                        ${stockStatus}
                    </tr>
                `;
            });
        }
    });

    bomBody.innerHTML = html;
}

function getStatusColor(status) {
    switch (status) {
        case 'Disponible': return '#4CAF50';
        case 'Parcialmente disponible': return '#FF9800';
        case 'Sin stock': return '#F44336';
        default: return '#6B7DB3';
    }
}

async function verificarInventarioEnAlmacen() {
    if (!bomCalculo) return;

    const btn = document.getElementById('btn-check-inventory');
    const originalText = btn.innerText;
    btn.innerText = "⏳ Verificando...";
    btn.disabled = true;

    try {
        // Preparar lista plana de items para el backend
        const allItems = [
            ...bomCalculo.tuberias,
            ...bomCalculo.accesorios,
            ...bomCalculo.valvulas
        ].map(i => ({
            description: i.descripcion,
            quantity: parseFloat(i.cantidad)
        }));

        const response = await fetch('http://127.0.0.1:8000/inventory/check-bom', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(allItems)
        });

        if (!response.ok) throw new Error('Error al conectar con el Almacén');

        const infoStock = await response.json();
        actualizarTablaBOM(bomCalculo, infoStock);
        btn.innerText = "✅ Verificado";

    } catch (err) {
        console.error(err);
        alert("No se pudo conectar con el sistema de Almacén. Asegúrate de que el Backend (Puerto 8000) esté corriendo.");
        btn.innerText = "❌ Error";
    } finally {
        setTimeout(() => {
            btn.innerText = originalText;
            btn.disabled = false;
        }, 3000);
    }
}

// Listeners para BOM
const btnCheckInventory = document.getElementById('btn-check-inventory');
if (btnCheckInventory) {
    btnCheckInventory.onclick = verificarInventarioEnAlmacen;
}

// Listeners para BOM
btnShowBom.onclick = () => {
    if (!bomCalculo) {
        alert('Primero debes hacer clic en "⚡ Generar Plano" para calcular los materiales de tu diseño.');
        return;
    }
    bomModal.classList.remove('hidden');
};

btnCloseBom.onclick = () => bomModal.classList.add('hidden');

btnCopyBom.onclick = () => {
    if (!bomCalculo) return;

    let text = "LISTA DE MATERIALES - AIRpipe\n\n";
    const categories = [
        { key: 'tuberias', title: 'TUBERÍAS' },
        { key: 'accesorios', title: 'ACCESORIOS' },
        { key: 'valvulas', title: 'VÁLVULAS' }
    ];

    categories.forEach(cat => {
        const items = bomCalculo[cat.key];
        if (items && items.length > 0) {
            text += `--- ${cat.title} ---\n`;
            items.forEach(item => {
                text += `${item.descripcion}: ${item.cantidad} ${item.unidad}\n`;
            });
            text += "\n";
        }
    });

    navigator.clipboard.writeText(text).then(() => {
        const originalText = btnCopyBom.innerText;
        btnCopyBom.innerText = "✅ ¡Copiado!";
        setTimeout(() => btnCopyBom.innerText = originalText, 2000);
    });
};

svgModal.addEventListener('click', (e) => {
    if (e.target === svgModal) {
        svgModal.classList.add('hidden');
        svgContainer.innerHTML = '';
    }
});

// ─────────────────────────────────────────────
//  Eventos del canvas
// ─────────────────────────────────────────────

const SNAP_RADIUS = 15;
const SNAP_ANGLE = 15;
const SNAP_GUIDE_TOLERANCE = 10;
const ANGULOS_SNAP = [0, 45, 90, 135, 180, 225, 270, 315];

let snapPoint = null;      // {x, y} si hay snap a punto
let angleSnapPoint = null; // {x, y, angle} si hay snap angular
let smartSnapPoint = null; // {x, y} si hay snap inteligente (guías)
let activeGuides = [];     // Lista de líneas guía para dibujar {x1, y1, x2, y2}

/**
 * OPT-3: Usa el cache de puntos en lugar de iterar historial.
 * Busca el punto de interés más cercano dentro de SNAP_RADIUS.
 */
function getSnapPoint(x, y) {
    const puntos = getSnapPoints(); // cache
    const currentSnapRadius = SNAP_RADIUS / viewState.scale;
    let closest = null;
    let minDist = Infinity;

    for (const p of puntos) {
        const dist = Math.hypot(p.x - x, p.y - y);
        if (dist <= currentSnapRadius && dist < minDist) {
            minDist = dist;
            closest = p;
        }
    }

    return closest;
}

/**
 * Calcula el punto final ajustado al ángulo más cercano si está dentro de la tolerancia.
 */
function getAngleSnapPoint(x1, y1, x2, y2) {
    const dx = x2 - x1;
    const dy = y2 - y1;
    const dist = Math.hypot(dx, dy);

    if (dist < 10) return null;

    let angle = Math.atan2(dy, dx) * (180 / Math.PI);
    if (angle < 0) angle += 360;

    let closestAngle = null;
    let minDiff = Infinity;

    for (const a of ANGULOS_SNAP) {
        let diff = Math.abs(angle - a);
        if (diff > 180) diff = 360 - diff;
        if (diff < minDiff) {
            minDiff = diff;
            closestAngle = a;
        }
    }

    if (minDiff <= SNAP_ANGLE) {
        const rad = closestAngle * (Math.PI / 180);
        return {
            x: x1 + dist * Math.cos(rad),
            y: y1 + dist * Math.sin(rad),
            angle: closestAngle
        };
    }

    return null;
}

/**
 * OPT-3: Usa el cache de puntos en lugar de iterar historial.
 * Busca alineaciones con puntos existentes (X o Y).
 */
function getSmartSnap(mouseX, mouseY) {
    const puntos = getSnapPoints(); // cache
    const currentGuideTolerance = SNAP_GUIDE_TOLERANCE / viewState.scale;

    let bestX = null;
    let bestY = null;
    let minDistX = Infinity;
    let minDistY = Infinity;

    activeGuides = [];

    for (const p of puntos) {
        const diffX = Math.abs(p.x - mouseX);
        if (diffX <= currentGuideTolerance && diffX < minDistX) {
            minDistX = diffX;
            bestX = p.x;
        }
        const diffY = Math.abs(p.y - mouseY);
        if (diffY <= currentGuideTolerance && diffY < minDistY) {
            minDistY = diffY;
            bestY = p.y;
        }
    }

    if (bestX === null && bestY === null) return null;

    const result = { x: mouseX, y: mouseY };

    if (bestX !== null) {
        result.x = bestX;
        for (const p of puntos) {
            if (Math.abs(p.x - bestX) < 0.1) {
                activeGuides.push({ x1: p.x, y1: p.y, x2: result.x, y2: result.y });
                break;
            }
        }
    }

    if (bestY !== null) {
        result.y = bestY;
        for (const p of puntos) {
            if (Math.abs(p.y - bestY) < 0.1) {
                activeGuides.push({ x1: p.x, y1: p.y, x2: result.x, y2: result.y });
                break;
            }
        }
    }

    return result;
}

/**
 * Busca la línea más cercana al punto (x, y) y devuelve el punto proyectado,
 * la línea original y el ángulo.
 */
function getLineSnap(x, y) {
    const TOLERANCIA = 20 / viewState.scale;
    let closest = null;
    let minDist = Infinity;

    for (const accion of historial) {
        if (accion.tipo !== 'linea') continue;
        const { x1, y1, x2, y2 } = accion.datos;

        // Proyección del punto sobre el segmento
        const A = x - x1;
        const B = y - y1;
        const C = x2 - x1;
        const D = y2 - y1;

        const dot = A * C + B * D;
        const len_sq = C * C + D * D;
        let param = -1;
        if (len_sq !== 0) param = dot / len_sq;

        let px, py;
        if (param < 0) {
            px = x1; py = y1;
        } else if (param > 1) {
            px = x2; py = y2;
        } else {
            px = x1 + param * C;
            py = y1 + param * D;
        }

        const dist = Math.hypot(x - px, y - py);
        if (dist < TOLERANCIA && dist < minDist) {
            minDist = dist;
            const angulo = Math.atan2(D, C) * (180 / Math.PI);
            closest = { x: px, y: py, angulo, linea: accion.datos };
        }
    }
    return closest;
}

canvas.addEventListener('wheel', (e) => {
    e.preventDefault();

    // OPT-4: usar canvasRect cacheado
    const mouseX = e.clientX - canvasRect.left;
    const mouseY = e.clientY - canvasRect.top;

    const worldBefore = toWorld(mouseX, mouseY);

    const zoomIntensity = 0.1;
    const direction = e.deltaY < 0 ? 1 : -1;
    let newScale = viewState.scale * (1 + direction * zoomIntensity);
    newScale = Math.min(Math.max(0.1, newScale), 5);

    viewState.scale = newScale;

    let nextOffsetX = mouseX - worldBefore.x * newScale;
    let nextOffsetY = mouseY - worldBefore.y * newScale;

    // OPT-10: usar constante MAX_CAMERA_OFFSET
    viewState.offsetX = Math.min(nextOffsetX, MAX_CAMERA_OFFSET);
    viewState.offsetY = Math.min(nextOffsetY, MAX_CAMERA_OFFSET);

    redraw();
}, { passive: false });

canvas.addEventListener('contextmenu', (e) => {
    const rawX = e.clientX - canvasRect.left;
    const rawY = e.clientY - canvasRect.top;
    const worldPos = toWorld(rawX, rawY);

    const hit = getCotaAt(worldPos.x, worldPos.y);
    if (hit) {
        e.preventDefault();
        // Invertir el offset (si es 0 o no existe, usar valor por defecto de 30)
        let currentOff = hit.cota.datos.offset;
        if (currentOff === undefined) currentOff = 30 / viewState.scale;
        hit.cota.datos.offset = -currentOff;

        invalidateSnapCache();
        redraw();
        setStatus("Lado de la cota alternado.");
    }
});

canvas.addEventListener('mousedown', (e) => {
    if (e.button === 1) {
        isPanning = true;
        lastPanX = e.clientX;
        lastPanY = e.clientY;
        e.preventDefault();
    }
});

canvas.addEventListener('mouseup', () => {
    isPanning = false;
});

canvas.addEventListener('click', (e) => {
    if (isPanning) return;

    // OPT-4: usar canvasRect cacheado
    const rawX = e.clientX - canvasRect.left;
    const rawY = e.clientY - canvasRect.top;

    const worldPos = toWorld(rawX, rawY);
    let x = worldPos.x;
    let y = worldPos.y;

    // Detectar clic en cota si no hay herramienta activa o estamos en modo acotar (y no hemos empezado una cota nueva)
    if (modoActual === MODO.NINGUNO || (modoActual === MODO.ACOTAR && !cotaInicio)) {
        const hit = getCotaAt(x, y);
        if (hit) {
            cotaSiendoEditada = hit.cota;
            const currentLen = (Math.hypot(hit.cota.datos.x2 - hit.cota.datos.x1, hit.cota.datos.y2 - hit.cota.datos.y1) / PIXELS_POR_METRO).toFixed(2);

            // Posicionar input flotante (en coordenadas de pantalla)
            floatingDimInput.style.display = 'block';
            floatingDimInput.style.left = `${e.clientX}px`;
            floatingDimInput.style.top = `${e.clientY}px`;
            floatingDimInput.value = currentLen;
            floatingDimInput.focus();
            floatingDimInput.select();
            return;
        }
    }

    // Prioridad 1: Snap a Punto
    if (snapPoint) {
        x = snapPoint.x;
        y = snapPoint.y;
    }
    // Prioridad 2: Snap Inteligente (Guías)
    else if (smartSnapPoint) {
        x = smartSnapPoint.x;
        y = smartSnapPoint.y;
    }
    // Prioridad 3: Snap Angular
    else if (modoActual === MODO.LINEA && lineaIniciada && angleSnapPoint) {
        x = angleSnapPoint.x;
        y = angleSnapPoint.y;
    }

    if (modoActual === MODO.LINEA) {
        if (!lineaIniciada) {
            lineaIniciada = true;
            puntoInicio = { x, y };
            setStatus('Punto de inicio fijado. Clic para terminar la tubería.');
        } else {
            historial.push({
                tipo: 'linea',
                datos: { x1: puntoInicio.x, y1: puntoInicio.y, x2: x, y2: y },
            });
            invalidateSnapCache(); // OPT-3
            lineaIniciada = false;
            puntoInicio = null;
            setStatus(`Tubería añadida. (${historial.filter(a => a.tipo === 'linea').length} en total)`);
            redraw();
        }
    } else if (modoActual === MODO.COMPRESOR) {
        historial.push({
            tipo: 'nodo',
            datos: { tipo: 'compresor', x, y },
        });
        invalidateSnapCache(); // OPT-3
        const xM = (x / PIXELS_POR_METRO).toFixed(2);
        const yM = (y / PIXELS_POR_METRO).toFixed(2);
        setStatus(`Compresor colocado en (${xM}m, ${yM}m).`);
        redraw();
    } else if (modoActual === MODO.CONSUMO) {
        historial.push({
            tipo: 'nodo',
            datos: { tipo: 'consumo', x, y },
        });
        invalidateSnapCache(); // OPT-3
        const xM = (x / PIXELS_POR_METRO).toFixed(2);
        const yM = (y / PIXELS_POR_METRO).toFixed(2);
        setStatus(`Punto de Consumo colocado en (${xM}m, ${yM}m).`);
        redraw();
    } else if (modoActual === MODO.VALVULA) {
        const snap = getLineSnap(x, y);
        if (snap) {
            historial.push({
                tipo: 'valvula_manual',
                datos: {
                    x: snap.x,
                    y: snap.y,
                    angulo: snap.angulo,
                    diametro: snap.linea.diametro || null // Si ya tiene diametro (raro en este punto pero bueno)
                },
            });
            setStatus('Válvula colocada sobre la tubería.');
            redraw();
        } else {
            setStatus('Debes hacer clic SOBRE una tubería para colocar la válvula.');
        }
    } else if (modoActual === MODO.ACOTAR) {
        if (!cotaInicio) {
            cotaInicio = { x, y };
            setStatus('Primer punto fijado. Clic en el segundo punto para completar la cota.');
        } else {
            const dist = Math.hypot(x - cotaInicio.x, y - cotaInicio.y);
            if (dist > 5) {
                historial.push({
                    tipo: 'cota',
                    datos: {
                        x1: cotaInicio.x, y1: cotaInicio.y,
                        x2: x, y2: y,
                        offset: 30 / viewState.scale
                    }
                });
                setStatus(`Cota añadida: ${(dist / PIXELS_POR_METRO).toFixed(2)}m`);
                redraw();
            }
            cotaInicio = null;
        }
    }
});

canvas.addEventListener('mousemove', (e) => {
    // 0. Manejar Pan (Arrastre)
    if (isPanning) {
        const deltaX = e.clientX - lastPanX;
        const deltaY = e.clientY - lastPanY;

        let nextOffsetX = viewState.offsetX + deltaX;
        let nextOffsetY = viewState.offsetY + deltaY;

        // OPT-10: usar constante MAX_CAMERA_OFFSET
        viewState.offsetX = Math.min(nextOffsetX, MAX_CAMERA_OFFSET);
        viewState.offsetY = Math.min(nextOffsetY, MAX_CAMERA_OFFSET);

        lastPanX = e.clientX;
        lastPanY = e.clientY;
        scheduleRedraw(); // OPT-1: usar RAF en lugar de redraw() directo
        return;
    }

    // OPT-4: usar canvasRect cacheado
    const rawX = e.clientX - canvasRect.left;
    const rawY = e.clientY - canvasRect.top;

    const worldPos = toWorld(rawX, rawY);
    const worldX = worldPos.x;
    const worldY = worldPos.y;

    // 1. Calcular Snap a Punto (usa cache OPT-3)
    snapPoint = getSnapPoint(worldX, worldY);

    // 2. Calcular Smart Snap (si no hay snap a punto)
    smartSnapPoint = null;
    if (!snapPoint) {
        smartSnapPoint = getSmartSnap(worldX, worldY);
    } else {
        activeGuides = [];
    }

    // 3. Calcular Snap Angular
    angleSnapPoint = null;
    if (modoActual === MODO.LINEA && lineaIniciada && puntoInicio && !snapPoint && !smartSnapPoint) {
        angleSnapPoint = getAngleSnapPoint(puntoInicio.x, puntoInicio.y, worldX, worldY);
    }

    // Determinar cursor lógico
    if (snapPoint) {
        puntoMouse = { x: snapPoint.x, y: snapPoint.y };
    } else if (smartSnapPoint) {
        puntoMouse = { x: smartSnapPoint.x, y: smartSnapPoint.y };
    } else if (angleSnapPoint) {
        puntoMouse = { x: angleSnapPoint.x, y: angleSnapPoint.y };
    } else if (modoActual === MODO.VALVULA) {
        const snap = getLineSnap(worldX, worldY);
        if (snap) {
            puntoMouse = { x: snap.x, y: snap.y, angulo: snap.angulo };
        } else {
            puntoMouse = { x: worldX, y: worldY };
        }
    } else {
        puntoMouse = { x: worldX, y: worldY };
    }

    // OPT-1: programar redraw con RAF en lugar de llamarlo directamente
    scheduleRedraw();
});

canvas.addEventListener('mouseleave', () => {
    puntoMouse = null;
    snapPoint = null;
    angleSnapPoint = null;
    smartSnapPoint = null;
    activeGuides = [];
    scheduleRedraw(); // OPT-1
});

// ── Eventos de Edición de Cotas ──

floatingDimInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
        finalizarEdicionCota(true);
    } else if (e.key === 'Escape') {
        finalizarEdicionCota(false);
    }
});

floatingDimInput.addEventListener('blur', () => {
    finalizarEdicionCota(false);
});

function finalizarEdicionCota(guardar) {
    if (!cotaSiendoEditada) return;

    if (guardar) {
        const nuevoMetros = parseFloat(floatingDimInput.value);
        if (!isNaN(nuevoMetros) && nuevoMetros > 0) {
            aplicarNuevaLongitud(cotaSiendoEditada, nuevoMetros);
        }
    }

    cotaSiendoEditada = null;
    floatingDimInput.style.display = 'none';
    redraw();
}

/** 
 * Actualiza la geometría de la cota y la tubería vinculada.
 * Usa "Rigid Stretch": desplaza toda la sub-red conectada al punto final,
 * preservando ángulos y longitudes de los tramos no editados.
 */
function aplicarNuevaLongitud(cota, nuevoMetros) {
    const pixels = nuevoMetros * PIXELS_POR_METRO;
    const { x1, y1, x2, y2 } = cota.datos;

    const dx = x2 - x1;
    const dy = y2 - y1;
    const lengthActual = Math.hypot(dx, dy);
    if (lengthActual < 1) return;

    const ux = dx / lengthActual;
    const uy = dy / lengthActual;

    const nuevoX2 = x1 + ux * pixels;
    const nuevoY2 = y1 + uy * pixels;

    const deltaX = nuevoX2 - x2;
    const deltaY = nuevoY2 - y2;

    // Si el delta es 0, no hay nada que hacer
    if (Math.abs(deltaX) < 0.01 && Math.abs(deltaY) < 0.01) return;

    // --- Paso 1: Encontrar la línea y la cota editadas por índice ---
    let lineaEditadaIdx = -1;
    const cotaEditadaIdx = historial.indexOf(cota);
    for (let i = 0; i < historial.length; i++) {
        const item = historial[i];
        if (item.tipo !== 'linea') continue;
        const d1 = Math.hypot(item.datos.x1 - x1, item.datos.y1 - y1);
        const d2 = Math.hypot(item.datos.x2 - x2, item.datos.y2 - y2);
        if (d1 < 2 && d2 < 2) { lineaEditadaIdx = i; break; }
        const d1r = Math.hypot(item.datos.x1 - x2, item.datos.y1 - y2);
        const d2r = Math.hypot(item.datos.x2 - x1, item.datos.y2 - y1);
        if (d1r < 2 && d2r < 2) { lineaEditadaIdx = i; break; }
    }

    // --- Paso 2: BFS para encontrar la sub-red conectada al punto (x2,y2) ---
    // Solo propagamos por LÍNEAS (no por cotas, que son anotaciones).
    // Excluimos la línea editada para no cruzar al otro extremo (x1,y1).

    // Usamos una key de punto redondeada para evitar errores de flotantes
    const ptKey = (px, py) => `${Math.round(px)},${Math.round(py)}`;

    const puntosAMover = new Set();
    const cola = [ptKey(x2, y2)];
    puntosAMover.add(ptKey(x2, y2));

    let head = 0;
    while (head < cola.length) {
        const currKey = cola[head++];
        const [cx, cy] = currKey.split(',').map(Number);

        for (let i = 0; i < historial.length; i++) {
            if (i === lineaEditadaIdx) continue; // No cruzar por la línea que estamos editando
            const item = historial[i];
            if (item.tipo !== 'linea') continue; // Solo propagamos por tuberías

            const k1 = ptKey(item.datos.x1, item.datos.y1);
            const k2 = ptKey(item.datos.x2, item.datos.y2);

            if (k1 === currKey && !puntosAMover.has(k2)) {
                puntosAMover.add(k2);
                cola.push(k2);
            }
            if (k2 === currKey && !puntosAMover.has(k1)) {
                puntosAMover.add(k1);
                cola.push(k1);
            }
        }
    }

    // --- Paso 3: Aplicar delta a todos los elementos EXCEPTO la línea y cota editadas ---
    for (let i = 0; i < historial.length; i++) {
        if (i === lineaEditadaIdx || i === cotaEditadaIdx) continue;

        const item = historial[i];
        if (item.tipo === 'linea' || item.tipo === 'cota') {
            const k1 = ptKey(item.datos.x1, item.datos.y1);
            if (puntosAMover.has(k1)) {
                item.datos.x1 += deltaX;
                item.datos.y1 += deltaY;
            }
            const k2 = ptKey(item.datos.x2, item.datos.y2);
            if (puntosAMover.has(k2)) {
                item.datos.x2 += deltaX;
                item.datos.y2 += deltaY;
            }
        } else if (item.tipo === 'nodo' || item.tipo === 'valvula_manual') {
            const k = ptKey(item.datos.x, item.datos.y);
            if (puntosAMover.has(k)) {
                item.datos.x += deltaX;
                item.datos.y += deltaY;
            }
        }
    }

    // --- Paso 4: Forzar posiciones exactas de la cota y línea editadas ---
    cota.datos.x2 = nuevoX2;
    cota.datos.y2 = nuevoY2;

    if (lineaEditadaIdx >= 0) {
        const lineaEd = historial[lineaEditadaIdx];
        const dA = Math.hypot(lineaEd.datos.x1 - x1, lineaEd.datos.y1 - y1);
        if (dA < 2) {
            lineaEd.datos.x2 = nuevoX2;
            lineaEd.datos.y2 = nuevoY2;
        } else {
            lineaEd.datos.x1 = nuevoX2;
            lineaEd.datos.y1 = nuevoY2;
        }
    }

    invalidateSnapCache();
    setStatus(`Longitud: ${nuevoMetros}m — Red actualizada.`);
}

// ─────────────────────────────────────────────
//  Eventos del Plano de Fondo (Blueprint)
// ─────────────────────────────────────────────

btnLoadBg.addEventListener('click', () => bgInput.click());

bgInput.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = (event) => {
        bgBase64 = event.target.result;
        bgUrl = null;
        cargarImagenFondo(bgBase64);
    };
    reader.readAsDataURL(file);
});

function cargarImagenFondo(base64Data) {
    const img = new Image();
    img.onload = () => {
        bgImageObj = img;
        bgControls.style.display = 'block';
        setStatus('Plano de fondo cargado.');

        // Restablecer valores de UI si no vienen de restore
        inputBgOpacity.value = bgOpacity * 100;
        valBgOpacity.textContent = `${bgOpacity * 100}%`;
        inputBgScale.value = bgScale;
        valBgScale.textContent = `${bgScale.toFixed(1)}x`;

        redraw();
    };
    img.src = base64Data;
}

inputBgOpacity.addEventListener('input', (e) => {
    bgOpacity = e.target.value / 100;
    valBgOpacity.textContent = `${e.target.value}%`;
    scheduleRedraw();
});

inputBgScale.addEventListener('input', (e) => {
    bgScale = parseFloat(e.target.value);
    valBgScale.textContent = `${bgScale.toFixed(1)}x`;
    scheduleRedraw();
});

btnRemoveBg.addEventListener('click', () => {
    bgImageObj = null;
    bgBase64 = null;
    bgUrl = null;
    bgScale = 1.0;
    bgOpacity = 0.5;
    bgInput.value = ''; // Limpiar input
    bgControls.style.display = 'none';
    setStatus('Plano de fondo removido.');
    redraw();
});

// ─────────────────────────────────────────────
//  Eventos del panel
// ─────────────────────────────────────────────

btnLine.addEventListener('click', () => setModo(MODO.LINEA));
btnCompresor.addEventListener('click', () => setModo(MODO.COMPRESOR));
btnConsumo.addEventListener('click', () => setModo(MODO.CONSUMO));
btnValvula.addEventListener('click', () => setModo(MODO.VALVULA));
btnAcotar.addEventListener('click', () => setModo(MODO.ACOTAR));
btnUndo.addEventListener('click', () => undo());
btnClear.addEventListener('click', () => clearAll());
btnGenerar.addEventListener('click', () => generarPlano());

// ─────────────────────────────────────────────
//  Input Manual (Dimensioning)
// ─────────────────────────────────────────────

function confirmarLongitudManual(distancia) {
    if (!puntoInicio || !puntoMouse) return;

    let dx = puntoMouse.x - puntoInicio.x;
    let dy = puntoMouse.y - puntoInicio.y;

    const currentDist = Math.hypot(dx, dy);

    if (currentDist < 0.1) {
        dx = 1; dy = 0;
    } else {
        dx /= currentDist;
        dy /= currentDist;
    }

    const pxDistancia = distancia * PIXELS_POR_METRO;
    const finalX = puntoInicio.x + dx * pxDistancia;
    const finalY = puntoInicio.y + dy * pxDistancia;

    historial.push({
        tipo: 'linea',
        datos: { x1: puntoInicio.x, y1: puntoInicio.y, x2: finalX, y2: finalY },
    });
    invalidateSnapCache(); // OPT-3

    lineaIniciada = false;
    puntoInicio = null;
    setStatus(`Tubería de ${distancia}m añadida.`);
    redraw();
}

lengthInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') {
        const val = parseFloat(lengthInput.value);
        if (!isNaN(val) && val > 0) {
            confirmarLongitudManual(val);
        }
        lengthInput.value = '';
        lengthInput.style.display = 'none';
        canvas.focus();
    } else if (e.key === 'Escape') {
        lengthInput.value = '';
        lengthInput.style.display = 'none';
        canvas.focus();
        e.stopPropagation();
    }
});

// ─────────────────────────────────────────────
//  OPT-8: Atajos de teclado unificados en un solo listener
// ─────────────────────────────────────────────

document.addEventListener('keydown', (e) => {
    // Si el input de longitud tiene el foco, dejar que maneje sus propios eventos
    if (document.activeElement === lengthInput) return;

    // ── Atajos globales ──
    if ((e.ctrlKey || e.metaKey) && e.key === 'z') {
        e.preventDefault();
        undo();
        return;
    }

    if (e.key === 'Escape') {
        if (lineaIniciada) {
            lineaIniciada = false;
            puntoInicio = null;
            setStatus('Tubería cancelada. Clic para iniciar una nueva.');
            redraw();
        }
        return;
    }

    // ── Input numérico (solo en modo línea activo) ──
    if (modoActual === MODO.LINEA && lineaIniciada && puntoInicio &&
        !e.ctrlKey && !e.altKey && !e.metaKey &&
        /^[0-9]$/.test(e.key) && puntoMouse) {

        const screenPos = toScreen(puntoMouse.x, puntoMouse.y);
        lengthInput.style.display = 'block';
        lengthInput.style.left = (screenPos.x + 20) + 'px';
        lengthInput.style.top = (screenPos.y + 20) + 'px';
        lengthInput.value = e.key;
        lengthInput.focus();
        e.preventDefault();
    }
});

// ─────────────────────────────────────────────
//  Resize
// ─────────────────────────────────────────────

window.addEventListener('resize', resizeCanvas);

// ─────────────────────────────────────────────
//  Gestión de Proyectos
// ─────────────────────────────────────────────

let proyectoActualId = null;
let proyectoActualName = '';

const projectsModal = document.getElementById('projects-modal');
const projectsSaveView = document.getElementById('projects-save-view');
const projectsListView = document.getElementById('projects-list-view');
const projectsList = document.getElementById('projects-list');
const projectsEmpty = document.getElementById('projects-empty');
const projectNameDisplay = document.getElementById('project-name-display');

function updateProjectDisplay() {
    if (proyectoActualId && proyectoActualName) {
        projectNameDisplay.textContent = `📌 ${proyectoActualName}`;
    } else {
        projectNameDisplay.textContent = '';
    }
}

function serializeProjectData() {
    return {
        historial: historial,
        viewState: viewState,
        tipo_red: document.getElementById('select-tipo-red').value,
        caudal_scfm: parseFloat(document.getElementById('input-caudal').value) || 0,
        // Guardar variables del plano de fondo
        bgBase64: bgBase64,
        bgUrl: bgUrl,
        bgOpacity: bgOpacity,
        bgScale: bgScale
    };
}

function restoreProjectData(data) {
    historial = data.historial || [];
    invalidateSnapCache();

    if (data.viewState) {
        viewState.scale = data.viewState.scale || 1.0;
        viewState.offsetX = data.viewState.offsetX || 0;
        viewState.offsetY = data.viewState.offsetY || 0;
    }

    if (data.tipo_red) {
        document.getElementById('select-tipo-red').value = data.tipo_red;
    }
    if (data.caudal_scfm) {
        document.getElementById('input-caudal').value = data.caudal_scfm;
    }

    // Restaurar plano de fondo si existe
    if (data.bgBase64 || data.bgUrl) {
        bgBase64 = data.bgBase64 || null;
        bgUrl = data.bgUrl || null;
        bgOpacity = data.bgOpacity !== undefined ? data.bgOpacity : 0.5;
        bgScale = data.bgScale !== undefined ? data.bgScale : 1.0;
        cargarImagenFondo(bgBase64 || bgUrl); // Esta función ya dibuja y actualiza UI cuando carga
    } else {
        // Asegurarse de quitarlo si el proyecto guardado no tiene fondo
        btnRemoveBg.click();
    }

    // Limpiar resultados de cálculo previos
    resultadosCalculo = null;
    piezasCalculo = null;
    valvulasCalculo = null;
    bomCalculo = null;

    lineaIniciada = false;
    puntoInicio = null;

    redraw();
}

// ── Guardar Proyecto ──
document.getElementById('btn-save-project').onclick = () => {
    projectsModal.classList.remove('hidden');
    projectsSaveView.style.display = 'block';
    projectsListView.style.display = 'none';

    const nameInput = document.getElementById('input-project-name');
    const clientInput = document.getElementById('input-project-client');

    if (proyectoActualName) {
        nameInput.value = proyectoActualName;
    }
    nameInput.focus();
};

document.getElementById('btn-confirm-save').onclick = async () => {
    const name = document.getElementById('input-project-name').value.trim();
    const client = document.getElementById('input-project-client').value.trim();

    if (!name) {
        alert('Por favor ingresa un nombre para el proyecto.');
        return;
    }

    const projectData = serializeProjectData();
    
    // UI Feedback: Deshabilitar botón y mostrar estado
    const btnConfirm = document.getElementById('btn-confirm-save');
    const originalText = btnConfirm.innerText;
    btnConfirm.disabled = true;
    btnConfirm.innerText = '💾 Guardando...';
    setStatus('Guardando proyecto en la nube...');

    try {
        let response;
        if (proyectoActualId) {
            // Actualizar proyecto existente
            response = await fetch(`${API_BASE}/projects/${proyectoActualId}`, {
                method: 'PUT',
                headers: getAuthHeaders(),
                body: JSON.stringify({ name, client, data: projectData })
            });
        } else {
            // Crear nuevo proyecto
            response = await fetch(`${API_BASE}/projects`, {
                method: 'POST',
                headers: getAuthHeaders(),
                body: JSON.stringify({ name, client, data: projectData })
            });
        }

        const result = await response.json();

        if (response.ok) {
            if (result.id) proyectoActualId = result.id;
            proyectoActualName = name;
            updateProjectDisplay();
            projectsModal.classList.add('hidden');
            setStatus(`Proyecto "${name}" guardado exitosamente.`);
        } else {
            console.error('Save Error Details:', result);
            alert('Error al guardar: ' + (result.error || 'Error desconocido del servidor'));
        }
    } catch (err) {
        console.error('Connection Error:', err);
        let msg = 'Error de conexión al guardar el proyecto.';
        if (err.name === 'TypeError' && err.message === 'Failed to fetch') {
            msg += '\n\nPosibles causas:\n- El servidor está caído.\n- Problemas con el túnel ngrok.\n- Tamaño de archivo demasiado grande para tu conexión.';
        } else {
            msg += '\nDetalle: ' + err.message;
        }
        alert(msg);
    } finally {
        // Restaurar botón
        btnConfirm.disabled = false;
        btnConfirm.innerText = originalText;
    }
};

document.getElementById('btn-cancel-save').onclick = () => {
    projectsModal.classList.add('hidden');
};

// ── Abrir / Listar Proyectos ──
document.getElementById('btn-open-project').onclick = async () => {
    projectsModal.classList.remove('hidden');
    projectsSaveView.style.display = 'none';
    projectsListView.style.display = 'block';

    try {
        const response = await fetch(`${API_BASE}/projects`, { headers: getAuthHeaders() });
        if (response.status === 401) { localStorage.removeItem('draw_token'); location.reload(); return; }
        const projects = await response.json();

        if (projects.length === 0) {
            projectsList.innerHTML = '';
            projectsEmpty.style.display = 'block';
            return;
        }

        projectsEmpty.style.display = 'none';
        projectsList.innerHTML = projects.map(p => {
            const date = new Date(p.updated_at).toLocaleDateString('es-MX', {
                day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit'
            });
            const clientStr = p.client ? ` — ${p.client}` : '';
            return `
                <li class="project-item">
                    <div class="project-info" data-id="${p.id}">
                        <div class="project-name">${p.name}</div>
                        <div class="project-meta">${date}${clientStr}</div>
                    </div>
                    <button class="project-delete" data-id="${p.id}" title="Eliminar">🗑</button>
                </li>
            `;
        }).join('');

        // Listeners para abrir
        projectsList.querySelectorAll('.project-info').forEach(el => {
            el.onclick = () => cargarProyecto(parseInt(el.dataset.id));
        });

        // Listeners para eliminar
        projectsList.querySelectorAll('.project-delete').forEach(el => {
            el.onclick = async (e) => {
                e.stopPropagation();
                const id = parseInt(el.dataset.id);
                if (!confirm('¿Eliminar este proyecto permanentemente?')) return;

                try {
                    const resp = await fetch(`${API_BASE}/projects/${id}`, {
                        method: 'DELETE',
                        headers: getAuthHeaders()
                    });
                    if (resp.status === 401) { localStorage.removeItem('draw_token'); location.reload(); return; }
                    if (proyectoActualId === id) {
                        proyectoActualId = null;
                        proyectoActualName = '';
                        updateProjectDisplay();
                    }
                    // Recargar lista
                    document.getElementById('btn-open-project').click();
                } catch (err) {
                    alert('Error al eliminar el proyecto.');
                }
            };
        });

    } catch (err) {
        console.error(err);
        alert('Error al cargar la lista de proyectos.');
    }
};

async function cargarProyecto(id) {
    try {
        const response = await fetch(`${API_BASE}/projects/${id}`, { headers: getAuthHeaders() });
        if (response.status === 401) { localStorage.removeItem('draw_token'); location.reload(); return; }
        if (!response.ok) throw new Error('Proyecto no encontrado');

        const project = await response.json();
        restoreProjectData(project.data);

        proyectoActualId = project.id;
        proyectoActualName = project.name;
        updateProjectDisplay();

        projectsModal.classList.add('hidden');
        setStatus(`Proyecto "${project.name}" cargado correctamente.`);
    } catch (err) {
        console.error(err);
        alert('Error al cargar el proyecto.');
    }
}

document.getElementById('btn-close-projects').onclick = () => {
    projectsModal.classList.add('hidden');
};

// ── Exportar a PDF ──

async function downloadPDF() {
    if (!proyectoActualId) {
        alert("Por favor guarda el proyecto antes de exportar el reporte PDF.");
        return;
    }

    setStatus("Generando reporte PDF...");

    // Capturar canvas como imagen
    // Nota: Para que se vea bien, podrías querer un fondo blanco
    const tempCanvas = document.createElement('canvas');
    tempCanvas.width = canvas.width;
    tempCanvas.height = canvas.height;
    const tempCtx = tempCanvas.getContext('2d');

    // Fondo blanco para el PDF
    tempCtx.fillStyle = '#FFFFFF';
    tempCtx.fillRect(0, 0, tempCanvas.width, tempCanvas.height);

    // Dibujar el contenido actual (simplificado: copiar el canvas principal)
    tempCtx.drawImage(canvas, 0, 0);

    const imagenB64 = tempCanvas.toDataURL('image/png');

    try {
        const response = await fetch(`${API_BASE}/projects/${proyectoActualId}/pdf`, {
            method: 'POST',
            headers: getAuthHeaders(),
            body: JSON.stringify({ imagen: imagenB64 })
        });

        if (response.status === 401) { localStorage.removeItem('draw_token'); location.reload(); return; }

        if (!response.ok) {
            const contentType = response.headers.get("content-type");
            if (contentType && contentType.includes("application/json")) {
                const err = await response.json();
                throw new Error(err.error || "Error al generar PDF");
            } else {
                const text = await response.text();
                console.error("Respuesta de error no-JSON:", text);
                throw new Error(`Error del servidor (${response.status}). Posible bloqueo de ngrok.`);
            }
        }

        const blob = await response.blob();
        const url = window.URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `Reporte_${proyectoActualName || 'Proyecto'}.pdf`;
        document.body.appendChild(a);
        a.click();
        window.URL.revokeObjectURL(url);
        document.body.removeChild(a);

        setStatus("Reporte PDF descargado.");
    } catch (err) {
        console.error(err);
        alert("Error al descargar el PDF: " + err.message);
        setStatus("Error al generar PDF.");
    }
}

document.getElementById('btn-download-pdf').onclick = downloadPDF;
document.getElementById('btn-download-pdf-bom').onclick = downloadPDF;

// Cerrar modal con clic en fondo
projectsModal.addEventListener('click', (e) => {
    if (e.target === projectsModal) {
        projectsModal.classList.add('hidden');
    }
});

// ─────────────────────────────────────────────
//  Inicialización
// ─────────────────────────────────────────────

resizeCanvas(); // También llama a updateCanvasRect() internamente
setStatus('AIRpipe listo para dibujar.');
